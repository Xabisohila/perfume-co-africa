# ── PayFast Credentials ───────────────────────────────────────────────────────
# Get from: https://www.payfast.co.za/merchant → Settings → Integration
PAYFAST_SANDBOX=false
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase

# ── App URL ───────────────────────────────────────────────────────────────────
# Production domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://www.perfume-co.co.za

# ── Turso Database ────────────────────────────────────────────────────────────
# Get from: https://app.turso.tech → your database → Connect
# Format: libsql://your-db-name-orgname.turso.io
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# Get from: turso db tokens create your-db-name
TURSO_AUTH_TOKEN=your_turso_auth_token
